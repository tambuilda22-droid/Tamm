-- Farm Loop (⚡BẢN NÂNG CẤP: DÍNH ĐẠN + DAMAGE CAO)
task.spawn(function()
    while task.wait() do -- Sử dụng task.wait() mặc định để mượt hơn
        if _G.AutoFarmCoin or _G.AutoKillLan then
            local char = lp.Character
            local head = char and char:FindFirstChild("Head")
            local enemies = workspace:FindFirstChild("Zombies") or workspace:FindFirstChild("Enemies")
            
            if head and enemies then
                local target = nil
                local dist = settings.range

                -- Quét tìm mục tiêu gần nhất
                for _, z in ipairs(enemies:GetChildren()) do
                    local zRoot = z:FindFirstChild("HumanoidRootPart")
                    local zHum = z:FindFirstChild("Humanoid")
                    
                    if zRoot and zHum and zHum.Health > 0 then
                        local magnitude = (zRoot.Position - head.Position).Magnitude
                        if magnitude < dist then
                            dist = magnitude
                            target = z
                        end
                    end
                end

                -- Nếu tìm thấy mục tiêu
                if target then
                    local zRoot = target:FindFirstChild("HumanoidRootPart")
                    local weapon = _G.AutoKillLan and "PzF 3" or "SMAW"
                    
                    -- ÉP TỌA ĐỘ DÍNH VÀO MỤC TIÊU (Sửa lỗi bay xuyên)
                    local args = {
                        [1] = {
                            ["ModelType"] = "Character",
                            ["TargetPos"] = zRoot.Position, -- Luôn bắn vào tâm quái
                            ["Model"] = target,
                            ["PlayerName"] = lp.Name,
                            ["WeaponName"] = weapon,
                            ["SourcePart"] = head,
                            ["SourcePos"] = head.Position
                        }
                    }
                    
                    -- GỬI PACKET THEO TỐC ĐỘ CỦA SLIDER
                    -- settings.damage_mult chính là số lần nhân sát thương
                    for i = 1, (settings.damage_mult or 10) do
                        remoteF:FireServer(unpack(args))
                    end
                    
                    -- Khoảng nghỉ dựa trên Slider để tránh bị kick (Anti-cheat)
                    task.wait(settings.attack_speed or 0.1) 
                end
            end
        end
    end
end)

--❄Vòng lặp Render xử lý di chuyển tuyết
RunService.RenderStepped:Connect(function(dt)
    if snowEnabled and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        if #snowflakes == 0 then
            snowFolder = snowFolder or Instance.new("Folder", workspace)
            for i = 1, 100 do
                local p = Instance.new("Part")
                p.Size = Vector3.new(0.2, 0.2, 0.2)
                p.Material = Enum.Material.Neon
                p.CanCollide = false
                p.Anchored = true
                p.Parent = snowFolder
                table.insert(snowflakes, {part = p, offset = Vector3.new(math.random(-50, 50), math.random(0, 40), math.random(-50, 50))})
            end
        end
        
        local rootPos = lp.Character.HumanoidRootPart.Position
        for _, data in ipairs(snowflakes) do
            data.offset = data.offset - Vector3.new(0, 15 * dt, 0)
            if data.offset.Y < -10 then
                data.offset = Vector3.new(math.random(-50, 50), 30, math.random(-50, 50))
            end
            data.part.Position = rootPos + data.offset
        end
    end
end)

