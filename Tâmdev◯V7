local originalIndex; originalIndex = hookmetamethod(game, "__index", function(self, property)
    if not checkcaller() and self:IsA("Humanoid") and self:IsDescendantOf(lp.Character) then
        local val = hooks[property:lower()]
        if val then return val end
    end
    return originalIndex(self, property)
end)

local originalNewIndex; originalNewIndex = hookmetamethod(game, "__newindex", function(self, property, value)
    if not checkcaller() and self:IsA("Humanoid") and self:IsDescendantOf(lp.Character) then
        local low = property:lower()
        if hooks[low] then hooks[low] = value return end
    end
    return originalNewIndex(self, property, value)
end)

