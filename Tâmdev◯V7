-- Tìm Zombie gần nhất còn sống
function GetClosestZombie()
    local closest = nil
    local dist = math.huge
    -- Lưu ý: Zombie Uprising thường để zombie trong Workspace.Zombies hoặc Workspace.Enemies
    local enemyFolder = workspace:FindFirstChild("Zombies") or workspace:FindFirstChild("Enemies") 
    
    if enemyFolder then
        for _, v in pairs(enemyFolder:GetChildren()) do
            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild(TargetPart) then
                local d = (lp.Character.Head.Position - v[TargetPart].Position).Magnitude
                if d < dist then
                    dist = d
                    closest = v
                end
            end
        end
    end
    return closest
end

-- Dự đoán vị trí dựa trên vận tốc (Prediction)
function GetPredictedTarget()
    local target = GetClosestZombie()
    if target then
        local part = target[TargetPart]
        local distance = (part.Position - lp.Character.Head.Position).Magnitude
        local timeToHit = distance / settings.BulletSpeed
        
        -- Công thức: Vị trí mới = Vị trí hiện tại + (Vận tốc * Thời gian bay)
        local predictedPos = part.Position + (part.Velocity * timeToHit)
        return predictedPos
    end
    return nil
end

