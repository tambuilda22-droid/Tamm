local snowEnabled = false
local snowflakes = {}
local snowFolder = nil
local maxSnowCount = 150

-- Hàm tạo hạt tuyết
local function createSnowflake()
    local p = Instance.new("Part")
    p.Size = Vector3.new(0.2, 0.2, 0.2)
    p.Material = Enum.Material.Neon
    p.Color = Color3.fromRGB(220, 240, 255)
    p.Transparency = 0.4
    p.CanCollide = false
    p.Anchored = true
    local mesh = Instance.new("SpecialMesh", p)
    mesh.MeshType = Enum.MeshType.Sphere
    return p
end

-- Hàm cập nhật số lượng tuyết
local function updateSnowCount(count)
    if not snowFolder then
        snowFolder = Instance.new("Folder", workspace)
        snowFolder.Name = "ChillSnowEffects"
    end
    
    -- Xóa bớt nếu giảm slider
    if #snowflakes > count then
        for i = #snowflakes, count + 1, -1 do
            if snowflakes[i] then
                snowflakes[i].part:Destroy()
                table.remove(snowflakes, i)
            end
        end
    -- Thêm mới nếu tăng slider
    elseif #snowflakes < count then
        for i = #snowflakes + 1, count do
            table.insert(snowflakes, {
                part = createSnowflake(),
                offset = Vector3.new(math.random(-60, 60), math.random(0, 50), math.random(-60, 60)),
                speed = math.random(80, 150) / 100
            })
        end
    end
    
    -- Cập nhật Parent dựa trên trạng thái Toggle
    for _, data in ipairs(snowflakes) do
        data.part.Parent = snowEnabled and snowFolder or nil
    end
end

